class Solution {
    public int scoreOfString(String s) {
        
        int sum = 0 ; 
        int total = 0;
        for(int i = 0 ; i < s.length()-1 ; i++)
        {
            //char ch = s.charAt(i);
            sum = s.charAt(i+1) - s.charAt(i);
            int ans = Math.abs(sum);
            total+=ans;
        }
        
        return total;
    }
}
